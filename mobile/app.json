{
  "expo": {
    "name": "Vida Mais",
    "slug": "vida-mais-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "primaryColor": "#FF7E00",
    "locales": {
      "pt": "./locales/pt-BR.json"
    },
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#075D94"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vidamais.app",
      "backgroundColor": "#FFFFFF",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "pt_BR",
        "CFBundleLocalizations": [
          "pt_BR"
        ],
        "NSCameraUsageDescription": "O aplicativo usa a câmera para login pelo reconhecimento facial."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF7E00"
      },
      "package": "com.vidamais.app",
      "backgroundColor": "#FFFFFF",
      "permissions": ["android.permission.CAMERA"],
      "intentFilters": []
    },
    "web": {},
    "scheme": "vidamais",
    "extra": {
      "eas": {
        "projectId": "21175ea8-ad33-405c-826b-0c4aa97a0f51"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-camera"
    ]
  }
}
