{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (Express + TypeScript)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "backend"
    },
    {
      "name": "Web Admin (Vite + React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "web-admin"
    },
    {
      "name": "Mobile (Expo)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 8081,
      "cwd": "mobile"
    },
    {
      "name": "ML Service (Flask)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["app.py"],
      "port": 5000,
      "cwd": "ml-service"
    },
    {
      "name": "Full Stack (Docker Compose)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "port": 80
    }
  ]
}
